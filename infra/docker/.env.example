# Host ports. Internal container ports remain stable and are not changed for hosting.
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
NATS_CLIENT_HOST_PORT=14222
NATS_MONITOR_HOST_PORT=18222
KEYCLOAK_HOST_PORT=8080
API_GATEWAY_HOST_PORT=8000
ADMIN_WEB_HOST_PORT=5173
MASTER_DATA_HOST_PORT=18081
SCHEDULE_HOST_PORT=18082
VENUE_HOST_PORT=18087
PROMETHEUS_HOST_PORT=19090
GRAFANA_HOST_PORT=13000
HTTP_HOST_PORT=80
HTTPS_HOST_PORT=443

# Redis
REDIS_PASSWORD=porprov_redis_secret

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret

# Grafana
GRAFANA_PASSWORD=admin
