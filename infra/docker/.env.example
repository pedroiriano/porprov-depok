# PostgreSQL
POSTGRES_USER=porprov_admin
POSTGRES_PASSWORD=porprov_secret
POSTGRES_DB=porprov_db

# Host ports. Internal container ports remain stable and are not changed for hosting.
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
NATS_CLIENT_HOST_PORT=14222
NATS_MONITOR_HOST_PORT=18222
KEYCLOAK_HOST_PORT=8080
API_GATEWAY_HOST_PORT=8000
ADMIN_WEB_HOST_PORT=5173
MASTER_DATA_HOST_PORT=18081
SCHEDULE_HOST_PORT=18082
VENUE_HOST_PORT=18087
PROMETHEUS_HOST_PORT=19090
GRAFANA_HOST_PORT=13000
HTTP_HOST_PORT=80
HTTPS_HOST_PORT=443

# Redis
REDIS_PASSWORD=porprov_redis_secret

# Service-to-service authentication. Replace before staging/production.
INTERNAL_STREAM_TOKEN=replace-with-a-long-random-internal-token

# API Gateway token validation and browser origins. Use the official HTTPS origin in production.
KEYCLOAK_ISSUER=http://localhost:8080/realms/porprov
JWT_ALLOWED_CLIENTS=porprov-admin-web,porprov-mobile-admin
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret

# Grafana
GRAFANA_PASSWORD=admin
